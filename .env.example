# Shared secret the ingest route checks on every Chainhook delivery.
# Generate with: openssl rand -hex 32
CHAINHOOK_AUTH_TOKEN=

# Your Supabase project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=

# Supabase service-role key. Secret, server-only, bypasses RLS. Never prefix with
# NEXT_PUBLIC and never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# The contract whose print events you index, e.g. SP....address.contract-name
CONTRACT_ID=

# Optional secondary filter on the decoded application topic. Leave unset to index
# every print event from the contract; set it to keep only one event topic.
EVENT_TOPIC=
