      "then_that": {
        "http_post": {
          "url": "<YOUR_DEPLOYMENT_URL>/api/chainhooks",
          "authorization_header": "Bearer <CHAINHOOK_AUTH_TOKEN>"
        }
      }
    }
  }
}
